{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npx -y pnpm@10.32.1 install",
  "buildCommand": "npx -y pnpm@10.32.1 --filter @workspace/portfolio run build",
  "outputDirectory": "artifacts/portifolio/dist/public",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "build": {
    "env": {
      "BASE_PATH": "/"
    }
  }
}
