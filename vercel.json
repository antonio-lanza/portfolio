{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd Portifolio && npx -y pnpm@10.32.1 install",
  "buildCommand": "cd Portifolio && npx -y pnpm@10.32.1 --filter @workspace/portfolio run build",
  "outputDirectory": "Portifolio/artifacts/portifolio/dist/public",
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!robots\\.txt|sitemap\\.xml|favicon\\.svg|opengraph\\.jpg|images/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ],
  "build": {
    "env": {
      "BASE_PATH": "/"
    }
  }
}
